# Public application origin. Set to the deployed HTTPS URL in production.
APP_BASE_URL=http://localhost:3000

# Local Docker PostgreSQL default. Use a pooled managed PostgreSQL URL on Vercel.
DATABASE_URL=postgresql://take_my_money:take_my_money@localhost:54329/take_my_money

# Generate at least 32 random bytes. Never expose this through NEXT_PUBLIC_*.
SESSION_SIGNING_SECRET=replace-with-at-least-32-random-bytes

# Optional. The deterministic fallback keeps the full demo usable without a key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
ENABLE_AI=true

# Public deployment accepts only version-controlled synthetic receipt assets.
ENABLE_CUSTOM_RECEIPT_UPLOAD=false
DEMO_MODE=true
DEMO_RESET_SECRET=
LOG_LEVEL=info
RUN_LIVE_AI_TESTS=false
